# Copy this file to .env for local Docker Compose development. Do not commit .env.
POSTGRES_DB=nstream
POSTGRES_USER=nstream
POSTGRES_PASSWORD=change-this-local-password
POSTGRES_PORT=5432
REDIS_PORT=6379
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
SERVER_PORT=8080

# Use a randomly generated value (at least 32 characters) outside local development.
NSTREAM_JWT_SECRET=replace-this-local-development-secret-before-deploying
